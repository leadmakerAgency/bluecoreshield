<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="canonical" href="{{ site.url }}{{ page.url | url }}">
  <link rel="alternate" type="application/atom+xml" title="Blue Core Shield Blog" href="{{ site.url }}/feed.xml">
  <meta name="description" content="{{ excerpt | default(title) }}">
  <title>{{ title }} | Blue Core Shield Blog</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="blog-post-page">
  <header class="header" id="header">
    <div class="container">
      <div class="header-inner">
        <a href="/index.html" class="logo">
          <img src="https://i.imgur.com/dc8vokc.png" alt="Blue Core Shield" class="logo-img">
        </a>
        <nav class="nav-menu" id="navMenu">
          <a href="/index.html" class="nav-link">Home</a>
          <a href="/about.html" class="nav-link">About</a>
          <div class="nav-item has-dropdown"><a href="/services.html" class="nav-link">Services <i class="fas fa-chevron-down nav-arrow"></i></a><div class="dropdown-menu"><a href="/services/armed-security.html" class="dropdown-link">Armed Security</a><a href="/services/unarmed-security.html" class="dropdown-link">Unarmed Security</a><a href="/services/mobile-patrol.html" class="dropdown-link">Mobile Patrol</a><div class="dropdown-divider"></div><a href="/services/fire-watch.html" class="dropdown-link">Fire Watch</a><a href="/services/construction-security.html" class="dropdown-link">Construction Security</a><a href="/services/event-security.html" class="dropdown-link">Event Security</a></div></div>
          <div class="nav-item has-dropdown"><a href="/industries.html" class="nav-link">Industries <i class="fas fa-chevron-down nav-arrow"></i></a><div class="dropdown-menu"><a href="/industries/retail.html" class="dropdown-link">Retail</a><a href="/industries/corporate.html" class="dropdown-link">Corporate Offices</a><a href="/industries/warehouse.html" class="dropdown-link">Warehouses &amp; Logistics</a><a href="/industries/construction.html" class="dropdown-link">Construction</a><div class="dropdown-divider"></div><a href="/industries/residential.html" class="dropdown-link">Residential &amp; HOA</a><a href="/industries/healthcare.html" class="dropdown-link">Healthcare</a><a href="/industries/hospitality.html" class="dropdown-link">Hospitality</a><a href="/industries/education.html" class="dropdown-link">Education</a><a href="/industries/events.html" class="dropdown-link">Events &amp; Venues</a></div></div>
          <div class="nav-item has-dropdown"><a href="/areas.html" class="nav-link">Service Areas <i class="fas fa-chevron-down nav-arrow"></i></a><div class="dropdown-menu"><a href="/areas/manhattan.html" class="dropdown-link">Manhattan</a><a href="/areas/brooklyn.html" class="dropdown-link">Brooklyn</a><a href="/areas/queens.html" class="dropdown-link">Queens</a><a href="/areas/bronx.html" class="dropdown-link">The Bronx</a><a href="/areas/staten-island.html" class="dropdown-link">Staten Island</a><div class="dropdown-divider"></div><a href="/areas/long-island.html" class="dropdown-link">Long Island</a><a href="/areas/westchester.html" class="dropdown-link">Westchester</a><a href="/areas/new-jersey.html" class="dropdown-link">Northern New Jersey</a></div></div>
          <a href="/blog/" class="nav-link active">Blog</a>
          <a href="/contact.html" class="nav-link">Contact</a>
        </nav>
        <div class="header-cta">
          <a href="tel:+12125550180" class="header-phone"><i class="fas fa-phone"></i> (212) 555-0180</a>
          <a href="/contact.html" class="btn btn-primary btn-sm">Get a Quote</a>
        </div>
        <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </header>

  <section class="page-header">
    <div class="container">
      <div class="page-header-content">
        <div class="breadcrumb"><a href="/index.html">Home</a> <span>/</span> <a href="/blog/">Blog</a> <span>/</span> <span class="current">{{ title }}</span></div>
        <h1>{{ title }}</h1>
        <p>{{ date | postDate }}</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container container-sm">
      {% if featured_image %}
      <figure class="blog-post-featured-image">
        <img src="{{ featured_image }}" alt="{{ title }}">
      </figure>
      {% endif %}

      <article class="blog-post-content">
        {{ content | safe }}
      </article>
    </div>
  </section>

  <section class="section bg-light">
    <div class="container">
      <div class="section-header text-center fade-up">
        <div class="section-label">More Articles</div>
        <h2 class="section-title">Related Posts</h2>
      </div>
      <div class="blog-grid">
        {% set relatedCount = 0 %}
        {% for post in collections.posts %}
        {% if post.url != page.url and relatedCount < 3 %}
        <article class="blog-card fade-up">
          <a href="{{ post.url }}" class="blog-card-full-link" aria-labelledby="related-post-title-{{ relatedCount }}">
            <div class="blog-thumb">
              {% if post.data.featured_image %}
              <img src="{{ post.data.featured_image }}" alt="" class="blog-thumb-image">
              {% else %}
              <span aria-hidden="true">{{ post.data.hero_emoji or "🛡️" }}</span>
              {% endif %}
            </div>
            <div class="blog-card-body">
              <div class="blog-date">{{ post.date | postDate }}</div>
              <h3 id="related-post-title-{{ relatedCount }}">{{ post.data.title }}</h3>
              <span class="service-link">Read article <i class="fas fa-arrow-right"></i></span>
            </div>
          </a>
        </article>
        {% set relatedCount = relatedCount + 1 %}
        {% endif %}
        {% endfor %}
      </div>
      <div class="text-center" style="margin-top: 2rem;">
        <a href="/blog/" class="btn btn-outline">Back to all articles</a>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="footer-main"><div class="container"><div class="footer-grid">
      <div class="footer-brand"><a href="/index.html" class="logo"><img src="https://i.imgur.com/JmI8hBC.png" alt="Blue Core Shield" class="logo-img logo-img-footer"></a><p>Licensed private security for New York City and the surrounding region. Trained professionals, transparent operations, and coverage you can rely on.</p></div>
      <div><h4>Services</h4><ul class="footer-links"><li><a href="/services/armed-security.html">Armed Security</a></li><li><a href="/services/unarmed-security.html">Unarmed Security</a></li><li><a href="/services/mobile-patrol.html">Mobile Patrol</a></li><li><a href="/services/fire-watch.html">Fire Watch</a></li><li><a href="/services/construction-security.html">Construction Security</a></li><li><a href="/services/event-security.html">Event Security</a></li></ul></div>
      <div><h4>Company</h4><ul class="footer-links"><li><a href="/about.html">About Us</a></li><li><a href="/industries.html">Industries</a></li><li><a href="/areas.html">Service Areas</a></li><li><a href="/blog/">Blog</a></li><li><a href="/contact.html">Contact</a></li></ul></div>
      <div><h4>Contact</h4><div class="footer-contact-item"><i class="fas fa-phone"></i><span>(212) 555-0180</span></div><div class="footer-contact-item"><i class="fas fa-envelope"></i><span>info@bluecoreshield.com</span></div></div>
    </div></div></div>
    <div class="footer-bottom"><div class="container"><div class="footer-bottom-inner"><p>&copy; 2026 Blue Core Shield. All rights reserved.</p><div class="footer-bottom-links"><a href="#">Privacy Policy</a><a href="#">Terms of Service</a></div></div></div></div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
